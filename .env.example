# ─────────────────────────────────────────────────────────────────────────────
# furniture-web environment
#
# Copy to .env.local and fill in. Every NEXT_PUBLIC_* value is inlined into the
# browser bundle — never put a secret or server-only token behind that prefix.
#
# Outside production, the tardis backend URL falls back to http://localhost:8080
# when unset. In production a missing URL disables the feature honestly rather
# than silently pointing at localhost.
# ─────────────────────────────────────────────────────────────────────────────

# ── Consumer demo: tardis generation backend (client, public) ────────────────
# Base URL of the tardis backend. Dev/test default: http://localhost:8080.
# Leave unset in production only if the consumer demo is intentionally disabled.
NEXT_PUBLIC_API_URL=http://localhost:8080
# X-API-Key for the backend. Intentionally public (also read server-side by the
# /api/download proxy so iOS AR Quick Look works). Not a secret-grade key.
NEXT_PUBLIC_API_KEY=
# Marketing/landing site URL (used by the orphaned WaitlistGate only).
NEXT_PUBLIC_LANDING_URL=https://www.tardis-ai.com

# ── B2B embed demo (/demo) — canonical embed contract (client, public) ────────
# The demo installs the REAL tardis-embed loader. All five must be set for the
# demo to render; if any is missing, /demo shows an honest "not configured"
# state and never fabricates a product or calls a local service.
#
# Public loader bundle URL (the single <script src> a retailer drops in).
NEXT_PUBLIC_TARDIS_WIDGET_URL=
# tardis-edge resolver base URL (GET /resolve, header X-Tenant-Key).
NEXT_PUBLIC_TARDIS_EDGE_URL=
# Analytics collector base URL (POST /events).
NEXT_PUBLIC_TARDIS_COLLECTOR_URL=
# Publishable, origin-scoped tenant key (pk_...). Never an sk_ secret key.
NEXT_PUBLIC_TARDIS_KEY=
# A product SKU that resolves in edge for this key (the demo's data-product).
NEXT_PUBLIC_TARDIS_SAMPLE_PRODUCT=

# ── Server-only (BFF routes; never exposed to the browser) ───────────────────
# Gemini API key for /api/scrape enrichment. Optional — falls back to heuristics.
GEMINI_API_KEY=
# Notion integration token for /api/gate and /api/waitlist (lead capture).
NOTION_API_KEY=
# Notion database id that /api/waitlist writes leads into.
NOTION_DATABASE_ID=
